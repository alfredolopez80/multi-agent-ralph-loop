# .ralphrc - Ralph per-project configuration
# Generated by: ralph-init
# Docs: https://github.com/alfredolopez80/multi-agent-ralph-loop
#
# This file configures Ralph's behavior for THIS project.
# Values here override global defaults.
# Environment variables override values in this file.

# =============================================================================
# PROJECT IDENTIFICATION
# =============================================================================

# Project name (used in prompts and logging)
PROJECT_NAME="${PROJECT_NAME:-my-project}"

# Project type: javascript, typescript, python, rust, go, unknown
PROJECT_TYPE="${PROJECT_TYPE:-unknown}"

# =============================================================================
# LOOP SETTINGS
# =============================================================================

# Maximum iterations before stopping (safety limit)
MAX_ITERATIONS=25

# Timeout per Claude invocation (minutes)
CLAUDE_TIMEOUT_MINUTES=15

# =============================================================================
# CIRCUIT BREAKER
# =============================================================================

# Open circuit after N loops with no file changes
CB_NO_PROGRESS_THRESHOLD=3

# Open circuit after N loops with same error
CB_SAME_ERROR_THRESHOLD=5

# Cooldown before auto-recovery (minutes)
CB_COOLDOWN_MINUTES=30

# Auto-reset on startup (bypasses cooldown — less safe for unattended use)
CB_AUTO_RESET=false

# =============================================================================
# MODEL ROUTING
# =============================================================================

# Task complexity routing (1-10 scale)
# 1-4: fast model, 5-6: balanced, 7-10: max capability
# MODEL_SIMPLE="sonnet"
# MODEL_COMPLEX="opus"

# =============================================================================
# QUALITY GATES
# =============================================================================

# Run quality validation after each iteration
QUALITY_GATES_ENABLED=true

# Maximum fix attempts before escalation
MAX_FIX_ATTEMPTS=3

# =============================================================================
# SESSION
# =============================================================================

# Maintain context across loop iterations
SESSION_CONTINUITY=true

# Session expiration (hours)
SESSION_EXPIRY_HOURS=24

# Verbose logging
RALPH_VERBOSE=false
